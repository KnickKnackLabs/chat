#!/usr/bin/env bash
#MISE description="Chat status overview"
#USAGE flag "--as <as>" help="Your identity — shows unread count (default: $CHAT_IDENTITY)"
#USAGE flag "--chat <chat>" help="Chat name (default: $CHAT_CHANNEL or auto-detect)"
#USAGE flag "--json" help="Output as JSON object"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/chat.sh"
chat_resolve "${usage_chat:-}"
chat_require_file

chat_resolve_identity "${usage_as:-}"
agent="$CHAT_IDENTITY"
has_gum=false
command -v gum &>/dev/null && has_gum=true

# Safe grep -c that doesn't fail on 0 matches
count_matches() {
  grep -c "$@" || true
}

# --- Stats ---
total_msgs=$(count_matches '^### ' "$CHAT_FILE" 2>/dev/null)
total_lines=$(chat_line_count)

last_header=$(grep '^### ' "$CHAT_FILE" 2>/dev/null | tail -1 | sed 's/^### //' || true)

participants=$(grep '^### ' "$CHAT_FILE" 2>/dev/null | sed 's/^### //; s/ — .*//' | tr '[:upper:]' '[:lower:]' | sort -u || true)
if [ -n "$participants" ]; then
  p_count=$(echo "$participants" | wc -l | tr -d ' ')
  p_names=$(echo "$participants" | paste -sd ', ' -)
else
  p_count=0
  p_names=""
fi

# --- JSON output ---
if [ "${usage_json:-false}" = "true" ]; then
  unread=0
  [ -n "$agent" ] && unread=$(chat_count_new "$agent")

  last_sender=""
  last_time=""
  if [ -n "$last_header" ]; then
    last_sender=$(echo "$last_header" | sed -E 's/ — .*//')
    last_time=$(echo "$last_header" | sed -E 's/.* — //')
  fi

  # Build participants array
  if [ -n "$participants" ]; then
    p_json=$(echo "$participants" | jq -R . | jq -s .)
  else
    p_json="[]"
  fi

  # Build JSON — include unread only when --as is provided
  if [ -n "$agent" ]; then
    jq -n --arg name "$CHAT_NAME" --argjson msgs "$total_msgs" \
      --argjson unread "$unread" --arg last_sender "$last_sender" \
      --arg last_time "$last_time" --argjson participants "$p_json" \
      '{name: $name, msgs: $msgs, unread: $unread, last_sender: $last_sender, last_time: $last_time, participants: $participants}'
  else
    jq -n --arg name "$CHAT_NAME" --argjson msgs "$total_msgs" \
      --arg last_sender "$last_sender" --arg last_time "$last_time" \
      --argjson participants "$p_json" \
      '{name: $name, msgs: $msgs, last_sender: $last_sender, last_time: $last_time, participants: $participants}'
  fi
  exit 0
fi

# --- Human-readable output below ---

# --- Header ---
if [ "$has_gum" = true ]; then
  gum style --bold --foreground 39 --border rounded --padding "0 1" "chat · ${CHAT_NAME}"
else
  echo "=== chat · ${CHAT_NAME} ==="
fi

# --- How resolved ---
resolved=""
if [ -n "${usage_chat:-}" ]; then
  resolved="--chat flag"
elif [ -n "${CHAT_CHANNEL:-}" ]; then
  resolved="\$CHAT_CHANNEL"
else
  detected=$(_chat_detect_repo || true)
  if [ -n "$detected" ]; then
    remote_url=$(git -C "${CALLER_PWD:-$PWD}" remote get-url origin 2>/dev/null || true)
    resolved="git remote (${remote_url})"
  else
    resolved="global default"
  fi
fi

# Build info block
info="resolved  ${resolved}"
info="${info}\nmessages  ${total_msgs}"
info="${info}\nlines     ${total_lines}"
[ -n "$last_header" ] && info="${info}\nlast      ${last_header}"
[ -n "$p_names" ] && info="${info}\npeople    ${p_names} (${p_count})"

if [ "$has_gum" = true ]; then
  printf '%b\n' "$info" | gum style --padding "0 1"
else
  echo ""
  printf '%b\n' "$info" | sed 's/^/  /'
fi

# --- Unread ---
if [ -n "$agent" ]; then
  unread=$(chat_count_new "$agent")
  if [ "$unread" -gt 0 ]; then
    if [ "$has_gum" = true ]; then
      gum style --foreground 212 --bold --padding "0 1" "📬 ${unread} unread for ${agent}"
    else
      echo ""
      echo "  >>> ${unread} unread for ${agent}"
    fi
  else
    if [ "$has_gum" = true ]; then
      gum style --faint --padding "0 1" "No unread messages for ${agent}."
    else
      echo ""
      echo "  No unread messages for ${agent}."
    fi
  fi
fi

# --- Other chats ---
other_chats=""
for f in "$CHAT_DATA_DIR"/*.md; do
  [ -f "$f" ] || continue
  name=$(basename "$f" .md)
  [ "$name" = "$CHAT_NAME" ] && continue
  msgs=$(count_matches '^### ' "$f" 2>/dev/null)
  if [ -n "$other_chats" ]; then
    other_chats="${other_chats}, ${name} (${msgs})"
  else
    other_chats="${name} (${msgs})"
  fi
done

if [ -n "$other_chats" ]; then
  if [ "$has_gum" = true ]; then
    gum style --faint --padding "0 1" "other chats: ${other_chats}"
  else
    echo ""
    echo "  other chats: ${other_chats}"
  fi
fi
