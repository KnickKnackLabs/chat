#!/usr/bin/env bash
#MISE description="List available chats"
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$REPO_DIR/lib/chat.sh"

if ! compgen -G "$CHAT_DATA_DIR/*.md" >/dev/null 2>&1; then
  echo "No chats yet. Create one with: chat send --chat <name> --from <you> \"hello\""
  exit 0
fi

if command -v gum &>/dev/null; then
  # Pretty output with gum
  for f in "$CHAT_DATA_DIR"/*.md; do
    [ -f "$f" ] || continue
    name=$(basename "$f" .md)
    lines=$(wc -l < "$f" | tr -d ' ')
    msgs=$(grep -c '^### ' "$f" 2>/dev/null || echo "0")
    last=$(grep '^### ' "$f" | tail -1 | sed 's/^### //' 2>/dev/null || echo "—")
    default_marker=""
    [ "$name" = "$CHAT_DEFAULT" ] && default_marker=" (default)"

    gum style --foreground 39 --bold "${name}${default_marker}"
    echo "  ${msgs} messages, ${lines} lines"
    [ -n "$last" ] && echo "  last: ${last}"
    echo ""
  done
else
  # Plain output
  for f in "$CHAT_DATA_DIR"/*.md; do
    [ -f "$f" ] || continue
    name=$(basename "$f" .md)
    msgs=$(grep -c '^### ' "$f" 2>/dev/null || echo "0")
    default_marker=""
    [ "$name" = "$CHAT_DEFAULT" ] && default_marker=" (default)"
    echo "${name}${default_marker} — ${msgs} message(s)"
  done
fi
