#!/usr/bin/env bash
#MISE description="Mark messages as read (update your cursor)"
#USAGE flag "--for <for>" help="Your agent name"
set -eo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$REPO_DIR/lib/chat.sh"
chat_init

agent="${usage_for:?Usage: chat read --for AGENT_NAME}"
chat_set_cursor "$agent"
echo "Marked all messages as read for @${agent}."
